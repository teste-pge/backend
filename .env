# ==============================================================================
#  .env.example — Variáveis de ambiente para desenvolvimento local
#
#  Como usar:
#    cp .env.example .env
#    # Edite .env com os valores do seu ambiente (nunca commite o .env!)
#
#  O arquivo .env é lido automaticamente pelo docker-compose.
#  Cada variável tem um valor padrão seguro para desenvolvimento local.
# ==============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rideflow
DB_USER=rideflow
DB_PASS=rideflow

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=rideflow

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Quando a app roda fora do Docker: localhost:9094 (listener EXTERNAL)
# Quando a app roda dentro do Docker: kafka:9092 (listener INTERNAL, sobrescrito pelo docker-compose.yml)
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_CONSUMER_GROUP=rideflow-dev-group

# ── Servidor ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
