<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="SERVICE_NAME" value="rideflow-backend"/>
    <property name="SERVICE_VERSION" value="1.0.0"/>

    <!-- ══════════════════════════════════════════════════════════════
         DEV / TEST — Console colorido legível para humanos
         ══════════════════════════════════════════════════════════════ -->
    <springProfile name="dev | test | default">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${CONSOLE_LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ══════════════════════════════════════════════════════════════
         PROD / DOCKER — JSON estruturado (Logstash-compatible)
         ══════════════════════════════════════════════════════════════ -->
    <springProfile name="prod | docker">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"service":"${SERVICE_NAME}","version":"${SERVICE_VERSION}"}</customFields>
                <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
                <timeZone>UTC</timeZone>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>

        <!-- Reduzir ruído de libs em prod -->
        <logger name="org.springframework.kafka" level="WARN"/>
        <logger name="org.apache.kafka" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <logger name="org.flywaydb" level="INFO"/>
    </springProfile>

</configuration>
